    "directory": "gateway"
  },
  "bugs": {
    "url": "https://github.com/dip-proto/x402/issues"
  },
  "keywords": [
    "x402",
    "402",
    "payment-required",
    "paywall",
    "bunny",
    "bunnycdn",
    "bunny.net",
