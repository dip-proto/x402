  "author": "Frank Denis <github@pureftpd.org>",
  "license": "MIT",
  "homepage": "https://github.com/dip-proto/x402#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dip-proto/x402.git",
    "directory": "tools"
  },
  "bugs": {
    "url": "https://github.com/dip-proto/x402/issues"
  },
  "keywords": [
    "x402",
    "402",
    "payment-required",
    "cli",
    "stablecoin",
    "usdc",
    "viem",
    "evm",
    "payments",
    "web3"
  ],
  "bin": {
    "x402": "./x402.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "x402.ts",
    "config.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
